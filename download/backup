  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700;800&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">

  <style>
    *{box-sizing:border-box;margin:0;padding:0;}
    :root{
      --bg:#07080a;
      --panel:rgba(8,9,12,0.94);
      --surface:rgba(255,255,255,0.03);
      --surface2:rgba(255,255,255,0.05);
      --border:rgba(255,255,255,0.07);
      --border2:rgba(255,255,255,0.10);

      /* THEME */
      --accent:#7800d2;         /* main theme color */
      --accent2:#9a4dff;        /* lighter accent companion */
      --text:#f1f1f1;
      --muted:rgba(255,255,255,0.45);
      --success:#10b981;
      --shadow:0 20px 60px rgba(0,0,0,0.55);
    }

    html,body{height:100%;}
    body{
      font-family:'Space Grotesk',sans-serif;
      color:var(--text);
      background:var(--bg);
      overflow-x:hidden;
      min-height:100vh;
      display:flex;
      background-image:
        radial-gradient(ellipse 90vw 55vh at 50% -5%, rgba(120,0,210,0.14) 0%, transparent 58%),
        radial-gradient(ellipse 60vw 40vh at 95% 100%, rgba(154,77,255,0.08) 0%, transparent 55%);
    }
    a{color:inherit;text-decoration:none;}
    svg{display:block;}

    /* ===== TOP BAR (FIXED) =====
       Fix: previously the fixed header overlapped content on some screens.
       We use a constant --topbar-h and apply it to main padding-top.
    */
    :root{ --topbar-h: 58px; }

    .topbar{
      position:fixed;inset:0 0 auto 0;height:var(--topbar-h);
      display:flex;align-items:center;justify-content:space-between;
      padding:0 14px;
      background:rgba(7,8,10,0.86);
      border-bottom:1px solid var(--border);
      backdrop-filter:blur(20px);
      z-index:50;
    }
    .brand{
      display:flex;align-items:center;gap:10px;
      font-weight:800;font-size:13px;letter-spacing:.08em;text-transform:uppercase;
      user-select:none;
      min-width:0;
    }
    .logoDot{
      width:10px;height:10px;border-radius:99px;
      background:linear-gradient(135deg,var(--accent),var(--accent2));
      box-shadow:0 0 0 6px rgba(120,0,210,0.14);
      flex:0 0 auto;
    }
    .brandText{
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
    }
    .chip{
      display:inline-flex;align-items:center;gap:8px;
      border:1px solid var(--border2);background:var(--surface2);
      padding:8px 10px;border-radius:12px;
      color:var(--muted);font-weight:700;font-size:12px;
      white-space:nowrap;
    }

    /* ===== LAYOUT ===== */
    .main{
      flex:1;width:100%;
      padding:calc(var(--topbar-h) + 18px) 14px 40px;
    }
    .container{width:100%;max-width:960px;margin:0 auto;}

    @media(min-width:768px){
      :root{ --topbar-h: 62px; } /* slightly taller on desktop for nicer spacing */
      .topbar{padding:0 18px;}
      .main{padding:calc(var(--topbar-h) + 26px) 24px 44px;}
      .container{max-width:920px;}
      .brand{font-size:13px;}
    }

/* Disable text selection */
html, body, *{
  -webkit-user-select: none;
  -moz-user-select: none;
  user-select: none;
}

/* ===== MODAL ===== */
.modalOverlay{
  position:fixed;
  inset:0;
  display:none;
  align-items:center;
  justify-content:center;
  padding:18px;
  background:rgba(0,0,0,0.62);
  backdrop-filter:blur(10px);
  z-index:999;
}

.modalOverlay.isOpen{ display:flex; }

.modalCard{
  width:100%;
  max-width:440px;
  border-radius:16px;
  border:1px solid rgba(255,255,255,0.10);
  background:linear-gradient(180deg, rgba(8,9,12,0.92), rgba(8,9,12,0.86));
  box-shadow:0 26px 90px rgba(0,0,0,0.65);
  overflow:hidden;
}

.modalTop{
  display:flex;
  align-items:flex-start;
  gap:12px;
  padding:16px 16px 12px;
  border-bottom:1px solid rgba(255,255,255,0.07);
}

.modalIcon{
  width:36px;height:36px;border-radius:12px;
  border:1px solid rgba(120,0,210,0.28);
  background:rgba(120,0,210,0.12);
  color:var(--accent2);
  display:flex;align-items:center;justify-content:center;
  box-shadow:0 0 26px rgba(120,0,210,0.14);
  flex:0 0 auto;
}
.modalIcon svg{width:18px;height:18px;}

.modalText{flex:1;min-width:0;}
.modalTitle{font-weight:900;letter-spacing:-0.02em;}
.modalSub{margin-top:4px;color:rgba(255,255,255,0.60);font-size:12px;line-height:1.45;}

.modalClose{
  border:1px solid rgba(255,255,255,0.10);
  background:rgba(255,255,255,0.04);
  color:rgba(255,255,255,0.75);
  border-radius:12px;
  width:34px;height:34px;
  display:flex;align-items:center;justify-content:center;
  cursor:pointer;
}
.modalClose svg{width:16px;height:16px;}

.modalBody{padding:14px 16px 16px;}

.passRow{display:flex;flex-direction:column;gap:8px;margin-bottom:14px;}
.passLabel{font-size:12px;color:rgba(255,255,255,0.60);font-weight:800;}

.passBox{
  display:flex;align-items:center;justify-content:space-between;gap:10px;
  padding:12px 12px;
  border-radius:14px;
  border:1px solid rgba(255,255,255,0.10);
  background:rgba(255,255,255,0.03);
}
.passBox code{
  font-family:'DM Mono', monospace;
  font-size:13px;
  color:rgba(255,255,255,0.92);
}

.copyBtn{
  border:1px solid rgba(120,0,210,0.35);
  background:rgba(120,0,210,0.10);
  color:var(--accent2);
  padding:8px 10px;
  border-radius:12px;
  font-weight:900;
  cursor:pointer;
}

.modalActions{
  display:flex;
  gap:10px;
  justify-content:flex-end;
}

.ghostBtn{
  border:1px solid rgba(255,255,255,0.10);
  background:rgba(255,255,255,0.04);
  color:rgba(255,255,255,0.80);
  padding:10px 12px;
  border-radius:12px;
  font-weight:900;
  cursor:pointer;
}

.primaryBtn{
  display:inline-flex;align-items:center;gap:8px;
  padding:10px 12px;
  border-radius:12px;
  font-weight:900;
  color:#fff;
  border:1px solid rgba(120,0,210,0.45);
  background:linear-gradient(135deg, rgba(120,0,210,0.98), rgba(88,0,170,0.92));
  box-shadow:0 10px 34px rgba(120,0,210,0.18);
}



